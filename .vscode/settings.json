// Place your settings in this file to overwrite default and user settings.
{
  "files.exclude": {
    "out": false // set this to true to hide the "out" folder with the compiled JS files
  },
  "search.exclude": {
    "out": true // set this to false to include "out" folder in search results
  },
  "files.associations": {
    ".azure-pipelines/*.yml": "azure-pipelines"
  },
  "typescript.tsdk": "./node_modules/typescript/lib", // we want to use the TS server from our node_modules folder to control its version

  "[shellscript]": { "editor.defaultFormatter": "lumirelle.shell-format-rev" },
  "[properties]": { "editor.defaultFormatter": "lumirelle.shell-format-rev" },
  "[dotenv]": { "editor.defaultFormatter": "lumirelle.shell-format-rev" },
  "[ignore]": { "editor.defaultFormatter": "lumirelle.shell-format-rev" },
  "[zsh]": { "editor.defaultFormatter": "lumirelle.shell-format-rev" }
}
